# Copy this file to .env.local and fill in your values
# Never commit .env.local to source control

# Anthropic API key — used server-side to generate tickets with Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Figma API token — used server-side to fetch frame images
# Generate at: https://www.figma.com/settings > Personal access tokens
FIGMA_API_TOKEN=your_figma_personal_access_token_here
